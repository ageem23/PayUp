# Supabase connection settings.
# Copy this file to .env.local and fill in real values from your Supabase project
# (Project Settings → API). .env.local is gitignored and must not be committed.
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini receipt OCR (Story 6.3) — server-only, used by the /api/ocr route.
# Get a key from Google AI Studio. Never exposed to the client; the real value
# lives only in the gitignored .env.local.
GEMINI_API_KEY=your-gemini-api-key

# Optional — override the Gemini model used for OCR (e.g. if one is overloaded).
# Defaults to gemini-flash-lite-latest. Other valid IDs: gemini-2.5-flash-lite,
# gemini-flash-latest, gemini-2.5-flash, gemini-3.5-flash.
GEMINI_OCR_MODEL=gemini-flash-lite-latest
